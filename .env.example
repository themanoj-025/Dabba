# =============================================================================
# DABBA — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
#
#   cp .env.example .env
#
# All settings are read via `DabbaConfig` (pydantic-settings) with the
# DABBA_ prefix. You can also set them as environment variables.
#
# ─── PRODUCTION SECRETS ──────────────────────────────────────────────────
# In production, DO NOT store secrets in `.env` files on disk. Instead:
#
#   Option A — HashiCorp Vault:
#     vault kv put secret/dabba api_key=<value> database_url=<value>
#     Then inject at runtime via envconsul or a Vault agent sidecar.
#
#   Option B — AWS Secrets Manager:
#     aws secretsmanager create-secret --name dabba/prod --secret-string '{}'
#     Then fetch in config via boto3 and pydantic's @field_validator.
#
#   Option C — Docker Secrets:
#     Mount /run/secrets/dabba_* files and read them in config.
#
# For local dev, `.env` is fine — just don't commit it.
# =============================================================================


# ─── Database ─────────────────────────────────────────────────────────────
# SQLite (dev):
#   DABBA_DATABASE_URL=sqlite:///data/dabba.db
# Postgres (prod):
#   DABBA_DATABASE_URL=postgresql://user:password@host:5432/dabba
# In-memory (testing):
#   DABBA_DATABASE_URL=sqlite:///:memory:
DABBA_DATABASE_URL=sqlite:///data/dabba.db


# ─── Redis Cache ──────────────────────────────────────────────────────────
# Redis connection string for caching hot predictions.
# Falls back to fakeredis automatically if unavailable.
DABBA_REDIS_URL=redis://localhost:6379/0
DABBA_CACHE_ETA_TTL_SECONDS=300
DABBA_CACHE_RECOMMEND_TTL_SECONDS=600


# ─── API Auth ─────────────────────────────────────────────────────────────
# API key for backend-to-backend authentication.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
DABBA_API_KEY=change-me-to-a-random-secret


# ─── LLM (Anthropic Claude) ──────────────────────────────────────────────
# Get your API key at https://console.anthropic.com/
# Set DABBA_LLM_ENABLED=true to activate the concierge agent.
DABBA_ANTHROPIC_API_KEY=
DABBA_LLM_ENABLED=false
DABBA_LLM_MODEL=claude-sonnet-4-20250514
DABBA_LLM_MAX_TOKENS=1000
DABBA_LLM_MAX_STEPS=4


# ─── MLflow Tracking ──────────────────────────────────────────────────────
# URI for the MLflow tracking server. Local server:
#   mlflow server --host 0.0.0.0 --port 5000
DABBA_MLFLOW_TRACKING_URI=http://localhost:5000
DABBA_MLFLOW_EXPERIMENT_NAME=dabba


# ─── External Traffic APIs ────────────────────────────────────────────────
# At least one required for real-time traffic data in ETA predictions.
# If both are unset, falls back to time-of-day simulation.
#
# TomTom:   https://developer.tomtom.com/  (free tier: 2500 requests/day)
# Mappls:   https://www.mappls.com/        (India-specific, free tier avail.)
DABBA_TOMTOM_API_KEY=
DABBA_MAPPLS_API_KEY=


# ─── Slack Alerting (Drift Detection) ─────────────────────────────────────
# Incoming Webhook URL for drift alerts.
# Create one: https://api.slack.com/messaging/webhooks
DABBA_SLACK_WEBHOOK_URL=
DABBA_SLACK_ALERT_CHANNEL=#dabba-drift
DABBA_DRIFT_ALERT_COOLDOWN_HOURS=24


# ─── Drift Detection ──────────────────────────────────────────────────────
DABBA_DRIFT_KS_THRESHOLD=0.05
DABBA_DRIFT_FEATURE_SAMPLE=100


# ─── Optuna Hyperparameter Optimization ───────────────────────────────────
# Disable for quick local runs; enable for thorough model selection.
DABBA_OPTUNA_ENABLED=true
DABBA_OPTUNA_N_TRIALS=50
DABBA_OPTUNA_TIMEOUT_MINUTES=
# Comma-separated list of model families to tune
DABBA_OPTUNA_MODELS_TO_TUNE=XGBoost,LightGBM,CatBoost,RandomForest,GradientBoosting


# ─── ML Pipeline Parameters ──────────────────────────────────────────────
DABBA_RANDOM_SEED=42
DABBA_TEST_SIZE=0.2
DABBA_CV_FOLDS=5
DABBA_RATING_METRIC=mae
DABBA_ETA_METRIC=mae
DABBA_SLA_THRESHOLD_MINUTES=40.0
DABBA_LOG_LEVEL=INFO


# ─── Hybrid Recommender Weights ──────────────────────────────────────────
DABBA_HYBRID_WEIGHT_CONTENT=0.4
DABBA_HYBRID_WEIGHT_COLLABORATIVE=0.3
DABBA_HYBRID_WEIGHT_RELIABILITY=0.3


# ─── Reliability Score Weights ───────────────────────────────────────────
DABBA_RELIABILITY_W_RATING=0.4
DABBA_RELIABILITY_W_SENTIMENT=0.3
DABBA_RELIABILITY_W_DELAY=0.3
