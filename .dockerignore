# ─── Docker build context exclusion ──────────────────────────────
# Prevents sending large / unnecessary files to the Docker daemon

# Project source dependencies
.git/
.gitignore
.github/
notebooks/
tests/
*.md
Makefile
pyproject.toml
setup_kaggle.py
requirements.txt
.pre-commit-config.yaml
CONTRIBUTING.md
memory.md
routes.md
architecture.md
api-map.md
database-map.md
dependency-graph.md
CHANGELOG.md
SECURITY.md
CODE_OF_CONDUCT.md

# Large data files (downloaded at runtime)
data/raw/
data/processed/

# Model artifacts (regenerated at runtime)
models/*.pkl
models/*.joblib
models/*.pt
models/*.index
models/*.npy

# Reports (regenerated at runtime)
reports/

# Virtual environments
.venv/
venv/
env/

# Environment / Secrets
.env
.env.local
kaggle.json
*.pem
*.key

# IDE
.vscode/
.idea/

# Exclude other service Dockerfiles (keep entrypoint.sh for API build)
docker/streamlit.Dockerfile
docker/mlflow.Dockerfile

# OS
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.ruff_cache/
.pytest_cache/
